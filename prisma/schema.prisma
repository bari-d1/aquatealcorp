generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  role      String?
  cohort    String?
  province  String?
  referral  String?
  createdAt DateTime @default(now())
}

model CohortOption {
  id    Int    @id @default(autoincrement())
  label String @unique
  price String
}
